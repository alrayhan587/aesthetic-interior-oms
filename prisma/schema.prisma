// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id         String         @id @default(cuid())
  name       String
  phone      String?        @unique
  email      String?
  source     String?
  stage      LeadStage      @default(NEW)
  subStatus  LeadSubStatus?
  budget     Float?
  location   String?
  remarks    String?
  assignedTo String?
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  assignee      User?               @relation("UserAssignedLeads", fields: [assignedTo], references: [id])
  followUps     FollowUp[]
  notes         Note[]
  activities    ActivityLog[]
  statusHistory LeadStatusHistory[]
  assignments   LeadAssignment[]
  visits        Visit[]
  attachments   LeadAttachment[]
  notifications Notification[]

  @@index([assignedTo])
  @@index([email])
  @@index([phone])
}

model LeadAssignment {
  id         String                   @id @default(cuid())
  leadId     String
  userId     String
  department LeadAssignmentDepartment
  createdAt  DateTime                 @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leadId, department, userId])
  @@index([leadId])
  @@index([userId])
  @@index([department])
}

model LeadStatusHistory {
  id          String     @id @default(cuid())
  leadId      String
  lead        Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  oldStatus   LeadStage
  newStatus   LeadStage
  changedById String
  changedBy   User       @relation(fields: [changedById], references: [id], onDelete: Cascade)
  changedAt   DateTime   @default(now())

  @@index([leadId])
  @@index([changedById])
}

model ActivityLog {
  id          String       @id @default(cuid())
  leadId      String
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ActivityType
  description String
  createdAt   DateTime     @default(now())

  @@index([leadId])
  @@index([userId])
}

model FollowUp {
  id           String         @id @default(cuid())
  leadId       String
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedToId String
  assignedTo   User           @relation(fields: [assignedToId], references: [id], onDelete: Cascade)
  followupDate DateTime
  status       FollowUpStatus @default(PENDING)
  notes        String?
  createdAt    DateTime       @default(now())
  notifications Notification[]

  @@index([leadId])
  @@index([assignedToId])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([userId])
}

model User {
  id          String   @id @default(cuid())
  fullName    String
  email       String   @unique
  phone       String
  isActive    Boolean  @default(true)
  clerkUserId String?  @unique
  approvedById String?
  approvedAt   DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  approvedBy   User?               @relation("UserApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedUsers User[]             @relation("UserApprover")
  leads           Lead[]              @relation("UserAssignedLeads")
  followUps       FollowUp[]
  notes           Note[]
  activities      ActivityLog[]
  statusChanges   LeadStatusHistory[]
  userRoles       UserRole[]
  userDepartments UserDepartment[]
  leadAssignments LeadAssignment[]
  visitsAssigned  Visit[]             @relation("VisitAssignee")
  visitsCreated   Visit[]             @relation("VisitCreator")
  visitUpdateRequests       VisitUpdateRequest[] @relation("VisitUpdateRequestedBy")
  resolvedVisitUpdateRequests VisitUpdateRequest[] @relation("VisitUpdateResolvedBy")
  supportVisits             VisitSupportAssignment[] @relation("VisitSupportMember")
  supportVisitsAssignedBy   VisitSupportAssignment[] @relation("VisitSupportAssignedBy")
  supportVisitResults       VisitSupportResult[]
  notifications Notification[]
  signupNotifications Notification[] @relation("NotificationSubjectUser")
}

model Visit {
  id           String      @id @default(cuid())
  leadId        String
  assignedToId  String?
  scheduledAt   DateTime
  status        VisitStatus @default(SCHEDULED)
  projectSqft   Float?
  projectStatus ProjectStatus?
  location      String
  notes         String?
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  lead       Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo User?        @relation("VisitAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User         @relation("VisitCreator", fields: [createdById], references: [id], onDelete: Cascade)
  result     VisitResult?
  updateRequests VisitUpdateRequest[]
  supportAssignments VisitSupportAssignment[]
  supportResults VisitSupportResult[]
  notifications Notification[]

  @@index([leadId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([scheduledAt])
}

model VisitUpdateRequest {
  id                 String                   @id @default(cuid())
  visitId            String
  visit              Visit                     @relation(fields: [visitId], references: [id], onDelete: Cascade)
  type               VisitUpdateRequestType
  status             VisitUpdateRequestStatus  @default(PENDING)
  reason             String
  requestedScheduleAt DateTime?
  requestedById      String
  requestedBy        User                      @relation("VisitUpdateRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  resolvedById       String?
  resolvedBy         User?                     @relation("VisitUpdateResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  createdAt          DateTime                  @default(now())
  resolvedAt         DateTime?

  @@index([visitId])
  @@index([status])
  @@index([requestedById])
  @@index([resolvedById])
}

model VisitResult {
  id           String       @id @default(cuid())
  visitId       String       @unique
  summary      String
  measurements Json?
  clientMood   String?
  clientPotentiality String?
  projectType String?
  clientPersonality String?
  budgetRange String?
  timelineUrgency String?
  stylePreference String?
  completedAt  DateTime     @default(now())

  visit Visit         @relation(fields: [visitId], references: [id], onDelete: Cascade)
  files Attachment[]
}

model VisitSupportAssignment {
  id            String   @id @default(cuid())
  visitId        String
  supportUserId  String
  assignedById   String
  createdAt      DateTime @default(now())

  visit       Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  supportUser User  @relation("VisitSupportMember", fields: [supportUserId], references: [id], onDelete: Cascade)
  assignedBy  User  @relation("VisitSupportAssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)
  result      VisitSupportResult?

  @@unique([visitId, supportUserId])
  @@index([visitId])
  @@index([supportUserId])
}

model VisitSupportResult {
  id                  String   @id @default(cuid())
  visitId             String
  supportAssignmentId String   @unique
  supportUserId       String
  clientName          String
  projectArea         String
  projectStatus       String
  extraConcern        String?
  completedAt         DateTime @default(now())

  visit              Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  supportAssignment  VisitSupportAssignment @relation(fields: [supportAssignmentId], references: [id], onDelete: Cascade)
  supportUser        User @relation(fields: [supportUserId], references: [id], onDelete: Cascade)
  files              SupportAttachment[]

  @@unique([visitId, supportUserId])
  @@index([visitId])
  @@index([supportUserId])
}

model Attachment {
  id            String      @id @default(cuid())
  url           String
  fileName      String
  fileType      String
  visitResultId String
  createdAt     DateTime    @default(now())

  visitResult VisitResult @relation(fields: [visitResultId], references: [id], onDelete: Cascade)

  @@index([visitResultId])
}

model LeadAttachment {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  url       String
  fileName  String
  fileType  String
  category  String
  sizeBytes Int?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([category])
}

model SupportAttachment {
  id                  String   @id @default(cuid())
  supportResultId     String
  url                 String
  fileName            String
  fileType            String
  createdAt           DateTime @default(now())

  supportResult VisitSupportResult @relation(fields: [supportResultId], references: [id], onDelete: Cascade)

  @@index([supportResultId])
}

model Notification {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId       String?
  lead         Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  followUpId   String?
  followUp     FollowUp?        @relation(fields: [followUpId], references: [id], onDelete: SetNull)
  visitId      String?
  visit        Visit?           @relation(fields: [visitId], references: [id], onDelete: SetNull)
  subjectUserId String?
  subjectUser User?            @relation("NotificationSubjectUser", fields: [subjectUserId], references: [id], onDelete: SetNull)
  type         NotificationType
  title        String
  message      String
  scheduledFor DateTime?
  isRead       Boolean          @default(false)
  readAt       DateTime?
  createdAt    DateTime         @default(now())

  @@index([userId])
  @@index([leadId])
  @@index([followUpId])
  @@index([visitId])
  @@index([subjectUserId])
  @@index([isRead])
  @@index([createdAt])
  @@unique([userId, followUpId, type])
  @@unique([userId, visitId, type])
  @@unique([userId, subjectUserId, type])
}

model FacebookSyncControl {
  id                      String   @id @default("default")
  enabled                 Boolean  @default(true)
  fallbackEnabled         Boolean  @default(true)
  fallbackIntervalMinutes Int      @default(15)
  batchLimit              Int      @default(20)
  lastSyncAt              DateTime?
  lastSyncStatus          String?
  lastSyncFetched         Int?
  lastSyncCreated         Int?
  lastSyncError           String?
  lastSyncTrigger         String?
  incrementalCursor       String?
  incrementalWatermark    DateTime?
  jrCrmRoundRobinOffset   Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model InstagramSyncControl {
  id                      String   @id @default("default")
  enabled                 Boolean  @default(true)
  fallbackEnabled         Boolean  @default(true)
  fallbackIntervalMinutes Int      @default(15)
  batchLimit              Int      @default(20)
  lastSyncAt              DateTime?
  lastSyncStatus          String?
  lastSyncFetched         Int?
  lastSyncCreated         Int?
  lastSyncError           String?
  lastSyncTrigger         String?
  incrementalCursor       String?
  incrementalWatermark    DateTime?
  jrCrmRoundRobinOffset   Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model WhatsAppWebhookControl {
  id                          String   @id @default("default")
  enabled                     Boolean  @default(true)
  lastWebhookAt               DateTime?
  lastWebhookStatus           String?
  lastWebhookError            String?
  lastProcessedMessages       Int      @default(0)
  lastCreatedLeads            Int      @default(0)
  lastSkippedExistingPhone    Int      @default(0)
  lastSkippedNoPhone          Int      @default(0)
  lastSkippedDuplicateMessage Int      @default(0)
  totalWebhookEvents          Int      @default(0)
  totalProcessedMessages      Int      @default(0)
  totalCreatedLeads           Int      @default(0)
  totalSkippedExistingPhone   Int      @default(0)
  totalSkippedNoPhone         Int      @default(0)
  totalSkippedDuplicateMessage Int     @default(0)
  jrCrmRoundRobinOffset       Int      @default(0)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model WhatsAppProcessedMessage {
  id        String   @id @default(cuid())
  messageId String   @unique
  phone     String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model WhatsAppWebhookEvent {
  id                     String   @id @default(cuid())
  status                 String
  source                 String?
  processedMessages      Int      @default(0)
  createdLeads           Int      @default(0)
  skippedExistingPhone   Int      @default(0)
  skippedNoPhone         Int      @default(0)
  skippedDuplicateMessage Int     @default(0)
  error                  String?
  createdAt              DateTime @default(now())

  @@index([createdAt])
}

enum LeadAssignmentDepartment {
  ADMIN
  SR_CRM
  JR_CRM
  QUOTATION
  VISIT_TEAM
  JR_ARCHITECT
  VISUALIZER_3D
}

model Role {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  userRoles   UserRole[]
}

model Department {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  userDepartments UserDepartment[]
}

model UserRole {
  userId     String
  roleId     String
  created_at DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model UserDepartment {
  userId       String
  departmentId String
  created_at   DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@index([departmentId])
}



enum LeadStage {
  NEW
  NUMBER_COLLECTED
  CONTACT_ATTEMPTED
  NURTURING
  VISIT_SCHEDULED
  VISIT_RESCHEDULED
  VISIT_COMPLETED
  VISIT_CANCELLED
  CLOSED
}

enum LeadSubStatus {
  NUMBER_COLLECTED
  NO_ANSWER
  WARM_LEAD
  FUTURE_CLIENT
  SMALL_BUDGET
  DEAD_LEAD
  INVALID
  NOT_INTERESTED
  LOST
}

enum FollowUpStatus {
  PENDING
  DONE
  LATELY_DONE
  MISSED
}

enum ActivityType {
  CALL
  STATUS_CHANGE
  NOTE
  FOLLOWUP_SET
  FOLLOWUP_COMPLETED
  VISIT_SCHEDULED
  LEAD_CREATED
  USER_ASSIGNED
}

enum VisitStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum ProjectStatus {
  UNDER_CONSTRUCTION
  READY
}

enum VisitUpdateRequestType {
  RESCHEDULE
  CANCEL
}

enum VisitUpdateRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  FOLLOWUP_DUE
  FOLLOWUP_REMINDER_15M
  VISIT_DUE
  VISIT_REMINDER_30M
  VISIT_ASSIGNED
  SIGNUP_PENDING_APPROVAL
  SIGNUP_APPROVED
  LEAD_ASSIGNED_TO_YOU
  FACEBOOK_LEAD_SYNC_SUMMARY
  VISIT_SCHEDULED_ADMIN
}
