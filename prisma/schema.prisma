// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id         String         @id @default(cuid())
  name       String
  phone      String         @unique
  email      String?
  source     String?
  stage      LeadStage      @default(NEW)
  subStatus  LeadSubStatus?
  budget     Float?
  location   String?
  remarks    String?
  assignedTo String?
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  assignee      User?               @relation("UserAssignedLeads", fields: [assignedTo], references: [id])
  followUps     FollowUp[]
  notes         Note[]
  activities    ActivityLog[]
  statusHistory LeadStatusHistory[]
  assignments   LeadAssignment[]
  visits        Visit[]

  @@index([assignedTo])
  @@index([email])
  @@index([phone])
}

model LeadAssignment {
  id         String                   @id @default(cuid())
  leadId     String
  userId     String
  department LeadAssignmentDepartment
  createdAt  DateTime                 @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leadId, department, userId])
  @@index([leadId])
  @@index([userId])
  @@index([department])
}

model LeadStatusHistory {
  id          String     @id @default(cuid())
  leadId      String
  lead        Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  oldStatus   LeadStage
  newStatus   LeadStage
  changedById String
  changedBy   User       @relation(fields: [changedById], references: [id], onDelete: Cascade)
  changedAt   DateTime   @default(now())

  @@index([leadId])
  @@index([changedById])
}

model ActivityLog {
  id          String       @id @default(cuid())
  leadId      String
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ActivityType
  description String
  createdAt   DateTime     @default(now())

  @@index([leadId])
  @@index([userId])
}

model FollowUp {
  id           String         @id @default(cuid())
  leadId       String
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedToId String
  assignedTo   User           @relation(fields: [assignedToId], references: [id], onDelete: Cascade)
  followupDate DateTime
  status       FollowUpStatus @default(PENDING)
  notes        String?
  createdAt    DateTime       @default(now())

  @@index([leadId])
  @@index([assignedToId])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([userId])
}

model User {
  id          String   @id @default(cuid())
  fullName    String
  email       String   @unique
  phone       String
  clerkUserId String?  @unique
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  leads           Lead[]              @relation("UserAssignedLeads")
  followUps       FollowUp[]
  notes           Note[]
  activities      ActivityLog[]
  statusChanges   LeadStatusHistory[]
  userRoles       UserRole[]
  userDepartments UserDepartment[]
  leadAssignments LeadAssignment[]
  visitsAssigned  Visit[]             @relation("VisitAssignee")
  visitsCreated   Visit[]             @relation("VisitCreator")
}

model Visit {
  id           String      @id @default(cuid())
  leadId        String
  assignedToId  String?
  scheduledAt   DateTime
  status        VisitStatus @default(SCHEDULED)
  location      String
  notes         String?
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  lead       Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo User?        @relation("VisitAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User         @relation("VisitCreator", fields: [createdById], references: [id], onDelete: Cascade)
  result     VisitResult?

  @@index([leadId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([scheduledAt])
}

model VisitResult {
  id           String       @id @default(cuid())
  visitId       String       @unique
  summary      String
  measurements Json?
  clientMood   String?
  completedAt  DateTime     @default(now())

  visit Visit         @relation(fields: [visitId], references: [id], onDelete: Cascade)
  files Attachment[]
}

model Attachment {
  id            String      @id @default(cuid())
  url           String
  fileName      String
  fileType      String
  visitResultId String
  createdAt     DateTime    @default(now())

  visitResult VisitResult @relation(fields: [visitResultId], references: [id], onDelete: Cascade)

  @@index([visitResultId])
}

enum LeadAssignmentDepartment {
  ADMIN
  SR_CRM
  JR_CRM
  QUOTATION
  VISIT_TEAM
  JR_ARCHITECT
  VISUALIZER_3D
}

model Role {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  userRoles   UserRole[]
}

model Department {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  userDepartments UserDepartment[]
}

model UserRole {
  userId     String
  roleId     String
  created_at DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model UserDepartment {
  userId       String
  departmentId String
  created_at   DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@index([departmentId])
}



enum LeadStage {
  NEW
  CONTACT_ATTEMPTED
  NURTURING
  VISIT_SCHEDULED
  CLOSED
}

enum LeadSubStatus {
  NUMBER_COLLECTED
  NO_ANSWER
  WARM_LEAD
  FUTURE_CLIENT
  SMALL_BUDGET
  DEAD_LEAD
  INVALID
  NOT_INTERESTED
  LOST
}

enum FollowUpStatus {
  PENDING
  DONE
  LATELY_DONE
  MISSED
}

enum ActivityType {
  CALL
  STATUS_CHANGE
  NOTE
  FOLLOWUP_SET
  FOLLOWUP_COMPLETED
  VISIT_SCHEDULED
  LEAD_CREATED
  USER_ASSIGNED
}

enum VisitStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}
